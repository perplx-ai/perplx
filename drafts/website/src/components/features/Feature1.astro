---
// Assets
import Kicker from "@/components/assets/Kicker.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const features = [
  {
    title: "Live research, not stale priors",
    subtitle:
      "Pulls current official documentation, release notes, and trustworthy web context via Perplexity-backed search—so the agent aligns with what vendors ship now, not a frozen training snapshot.",
  },
  {
    title: "Readable summaries before you run anything",
    subtitle:
      "Every non-trivial suggestion comes with a short explanation: what will change, why it’s grounded in up-to-date sources, and what to double-check—so you stay in control.",
  },
  {
    title: "Skills & repeatable workflows",
    subtitle:
      "Encode how your team likes to work—scripts, conventions, and guardrails—so the agent repeats your patterns instead of improvising every session.",
  },
] as const;
---

<section class="relative overflow-hidden bg-white">
  <Wrapper variant="standard" class="relative py-20 md:py-24">
    <div class="grid grid-cols-1 items-start gap-y-8 lg:grid-cols-8">
      <Kicker>Our solution</Kicker>
      <div class="relative text-balance lg:col-span-7">
        <Text
          tag="h2"
          variant="displaySM"
          class="font-display text-base-900 leading-snug lg:-mt-1"
        >
          Three things that make Perplx different: fresh context, transparent
          plans, and workflows you own.
        </Text>
        <Button
          size="xs"
          variant="muted"
          class="mt-6 w-fit"
          isLink={true}
          href="/pricing"
        >
          View plans
        </Button>

        <div class="mt-8 grid grid-cols-1 gap-px border border-base-200 bg-base-200 md:mt-9 md:grid-cols-3">
          {
            features.map((item) => (
              <div class="flex flex-col gap-2 bg-white p-5 sm:p-6">
                <Text tag="h3" variant="textBase" class="text-base-900">
                  {item.title}
                </Text>
                <Text tag="p" variant="textBase" class="leading-relaxed text-base-500">
                  {item.subtitle}
                </Text>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>
