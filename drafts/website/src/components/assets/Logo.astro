---
/**
 * Site mark — uses `public/icon.svg` (Perplx terminal octopus).
 */
const { class: className, ...rest } = Astro.props;
---

<img
  src="/icon.svg"
  alt=""
  class:list={["block w-auto max-w-none shrink-0 object-contain object-left", className]}
  width="104"
  height="70"
  loading="eager"
  decoding="async"
  {...rest}
/>
