---
// Assets
import { Image } from "astro:assets";
import Dots from "@/components/assets/Dots.astro";
import Burst from "@/components/assets/Burst.astro";
import Kicker from "@/components/assets/Kicker.astro";
import SectionDivider from "@/components/assets/SectionDivider.astro";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import BlogEntry from "@/components/blog/BlogEntry.astro";
// Load all posts
import { getCollection } from "astro:content";
// Content
const allPosts = await getCollection("posts");
// Get the team slug from the URL
const teamSlug = Astro.url.pathname.split("/").filter(Boolean).pop();
// Filter posts by this team (based on slug)
const relatedPosts = allPosts.filter((post) => post.data.team === teamSlug);
const { frontmatter } = Astro.props;
---

<BaseLayout>
  <section class="relative overflow-hidden">
    <Burst />
    <Dots />
    <SectionDivider />
    <Wrapper variant="standard" class="relative pt-30 lg:pt-60 pb-28">
      <div class="items-start grid grid-cols-1 lg:grid-cols-8 gap-y-8">
        <Kicker> {frontmatter.name}</Kicker>
        <Text
          tag="h1"
          variant="displayMD"
          class="font-display text-base-900 lg:-mt-1 text-balance lg:col-span-7"
        >
          {frontmatter.role}
        </Text>
      </div>
    </Wrapper>
  </section>
  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="items-start grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-8 bg-dots">
          <Image
            width={1000}
            height={800}
            alt={frontmatter.image.alt}
            src={frontmatter.image.url}
            class="relative object-cover object-top size-full aspect-square"
          />
        </div>

        <div class="flex flex-col justify-between h-full bg-white gap-8">
          <div class="space-y-4 text-balance">
            {
              frontmatter.bio.split("\n").map((paragraph) => (
                <Text tag="p" variant="textSM" class="text-base-600">
                  {paragraph}
                </Text>
              ))
            }
          </div>
          <div class="flex items-center mt-8 gap-2">
            <a
              href={frontmatter.socials.twitter}
              class="text-sm text-base-600 hover:text-accent-600 duration-300"
              aria-label="X"
            >
              Twitter
            </a>

            <a
              href={frontmatter.socials.linkedin}
              class="text-sm text-base-600 hover:text-accent-600 duration-300"
              aria-label="LinkedIn"
            >
              Linkedin
            </a>
            <a
              href={frontmatter.socials.email}
              class="text-sm text-base-600 hover:text-accent-600 duration-300"
              aria-label="Email"
            >
              Email
            </a>
            <a
              href={frontmatter.socials.website}
              class="text-sm text-base-600 hover:text-accent-600 duration-300"
              aria-label="Website"
            >
              Website
            </a>
          </div>
        </div>
      </div>
    </Wrapper>
  </section>
  {
    relatedPosts.length > 0 && (
      <section>
        <Wrapper variant="standard" class="py-12">
          <div class="items-start grid grid-cols-1 lg:grid-cols-8 gap-y-8">
            <Kicker> {frontmatter.name}</Kicker>
            <Text
              tag="h2"
              variant="displayMD"
              class="text-base-900 font-display lg:col-span-7 lg:-mt-1 "
            >
              More posts from
              <span class="capitalize">{teamSlug.replace(/-/g, " ")}</span>
            </Text>
          </div>

          <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-1">
            {relatedPosts.map((post) => (
              <BlogEntry post={post} />
            ))}
          </div>
        </Wrapper>
      </section>
    )
  }
</BaseLayout>
