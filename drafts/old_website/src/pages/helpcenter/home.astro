---
// Assets
import Dots from "@/components/assets/Dots.astro";
import Burst from "@/components/assets/Burst.astro";
import Kicker from "@/components/assets/Kicker.astro";
import SectionDivider from "@/components/assets/SectionDivider.astro";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import HelpCenterEntry from "@/components/helpcenter/HelpCenterEntry.astro";
// Sections
import Faq from "@/components/helpcenter/Faq.astro";
// Content
import { getCollection } from "astro:content";
// Content
const allEntries = await getCollection("helpcenter");
---

<BaseLayout>
  <section class="relative overflow-hidden">
    <Burst />
    <Dots />
    <SectionDivider />
    <Wrapper variant="standard" class="relative pt-30 lg:pt-60 pb-28">
      <div class="items-start grid grid-cols-1 lg:grid-cols-8 gap-y-8">
        <Kicker>Welp</Kicker>
        <div class="lg:col-span-7 text-balance">
          <Text
            tag="h1"
            variant="displayMD"
            class="font-display text-base-900 lg:-mt-1"
          >
            Help that actually helps
          </Text>
          <Text tag="p" variant="textBase" class="mt-1 text-base-700">
            Lost? Perplexed? Ready to flip your desk? Our docs are here to spare
            you the frantic searches and screen-based frustration.
          </Text>
        </div>
      </div>
    </Wrapper>
  </section>
  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-1">
        {allEntries.map((post) => <HelpCenterEntry post={post} />)}
      </div>
    </Wrapper>
  </section>
  <Faq />
</BaseLayout>
