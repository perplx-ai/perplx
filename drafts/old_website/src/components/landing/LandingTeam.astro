---
import Kicker from "@/components/assets/Kicker.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const team = [
  { name: "Rahul Suthar" },
  { name: "Jordan Walker" },
  { name: "Mateo Alado" },
  { name: "Sajjaad Farzad" },
] as const;
---

<section class="bg-base-50">
  <Wrapper variant="standard" class="relative py-20 md:py-24">
    <div class="grid grid-cols-1 gap-y-10 lg:grid-cols-8">
      <Kicker>Team</Kicker>
      <div class="lg:col-span-7">
        <Text
          tag="h2"
          variant="displaySM"
          class="font-display text-balance text-base-900 lg:-mt-1"
        >
          People
        </Text>
        <Text tag="p" variant="textLG" class="mt-5 max-w-3xl text-base-600">
          Building at the intersection of developer tools and live knowledge.
        </Text>
        <ul
          class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4"
        >
          {
            team.map((m) => (
              <li class="border border-base-200 bg-white px-6 py-8 text-center shadow-[var(--shadow-subtle)]">
                <div
                  class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-[#3b7a87]/15 font-display text-lg font-semibold text-[#3b7a87]"
                  aria-hidden="true"
                >
                  {m.name
                    .split(" ")
                    .map((p) => p[0])
                    .join("")}
                </div>
                <Text tag="p" variant="textBase" class="font-display font-semibold text-base-900">
                  {m.name}
                </Text>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Wrapper>
</section>
