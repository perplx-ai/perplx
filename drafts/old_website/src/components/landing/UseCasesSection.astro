---
import Kicker from "@/components/assets/Kicker.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const cases = [
  {
    title: "Vibe-coding & prototypes",
    body: "Move from idea to working branch fast—without cargo-culting outdated Stack Overflow answers when the framework moved on Tuesday.",
  },
  {
    title: "Production engineering",
    body: "Refactors, migrations, and dependency upgrades where the right move depends on release notes and breaking-change guides.",
  },
  {
    title: "Research & evaluation",
    body: "Compare libraries, APIs, and deployment options with citations you can trace—not a model’s best guess.",
  },
  {
    title: "Onboarding & handoffs",
    body: "Turn “how does this service work?” into a short, sourced brief aligned with current docs, so new teammates don’t pay the confusion tax.",
  },
] as const;
---

<section class="border-b border-base-200 bg-white">
  <Wrapper variant="standard" class="relative py-20 md:py-24">
    <div class="grid grid-cols-1 gap-y-10 lg:grid-cols-8">
      <Kicker>Use cases</Kicker>
      <div class="lg:col-span-7">
        <Text
          tag="h2"
          variant="displaySM"
          class="font-display text-balance text-base-900 lg:-mt-1"
        >
          Built for every kind of developer
        </Text>
        <Text tag="p" variant="textLG" class="mt-5 max-w-3xl text-base-600">
          From quick experiments to careful refactors, the same rule applies:
          when the ground truth lives on the web, the agent should read it before
          it ships a suggestion.
        </Text>
        <div
          class="mt-10 grid grid-cols-1 gap-px border border-base-200 bg-base-200 sm:grid-cols-2"
        >
          {
            cases.map((c) => (
              <div class="bg-white p-6 sm:p-7">
                <Text tag="h3" variant="textBase" class="font-display font-semibold text-base-900">
                  {c.title}
                </Text>
                <Text tag="p" variant="textBase" class="mt-2 leading-relaxed text-base-600">
                  {c.body}
                </Text>
              </div>
            ))
          }
        </div>
        <Text tag="p" variant="textSM" class="mt-8 text-base-500">
          Demo flows and recorded walkthroughs can live here as you ship them—swap
          this line for a video or interactive embed when ready.
        </Text>
      </div>
    </div>
  </Wrapper>
</section>
