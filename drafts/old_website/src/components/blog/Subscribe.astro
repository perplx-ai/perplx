---
// Assets
import Dots from "@/components/assets/Dots.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section>
  <Wrapper variant="standard" class="py-24">
    <div class="relative p-8 py-24 text-center">
      <Dots />
      <div class="relative text-balance max-w-xl mx-auto">
        <Text
          tag="h2"
          variant="displayMD"
          class="font-display text-base-900 text-balance"
        >
          Subscribe, unless you hate fun
        </Text>
        <Text tag="p" variant="textBase" class="mt-2 text-base-800">
          Get the latest posts, updates, and half-decent advice — straight to
          your inbox. No spam. Just vibes.
        </Text>
        <form class="max-w-sm mx-auto mt-12 space-y-2">
          <div class="w-full">
            <label for="email" class="sr-only">Email Address</label>
            <div class="focus-within:z-10 relative z-0">
              <input
                id="email"
                name="email"
                type="email"
                placeholder="you@example.com"
                class="block w-full px-4 py-2 text-xs leading-tight align-middle border border-transparent bg-base-50 transition duration-300 ease-in-out h-9 rounded-md text-base-500 focus:ring-1 placeholder-base-400 focus:ring-accent-500 focus:ring-2 focus:outline-none"
                inputmode="email"
              />
            </div>
          </div>
          <Button
            size="xs"
            variant="accent"
            gap="sm"
            type="submit"
            class="w-full"
          >
            Send Message
          </Button>
        </form>
      </div>
    </div>
  </Wrapper>
</section>
