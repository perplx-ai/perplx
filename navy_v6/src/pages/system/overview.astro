---
// Assets
import Dots from "@/components/assets/Dots.astro";
import Burst from "@/components/assets/Burst.astro";
import Kicker from "@/components/assets/Kicker.astro";
import SectionDivider from "@/components/assets/SectionDivider.astro";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Data array
const pageData = [
  {
    categoryTitle: "Static",
    links: [
      {
        sectionTitle: "Landing Pages",
        links: [
          {
            title: "Home",
            url: "/",
          },
          {
            title: "Pricing",
            url: "/pricing",
          },

          {
            title: "About",
            url: "/about",
          },
          { title: "404", url: "/404" },
        ],
      },
      {
        sectionTitle: "Forms ",
        links: [
          {
            title: "Contact",
            url: "/forms/contact",
          },
          {
            title: "Signin",
            url: "/forms/sign-in",
          },
          {
            title: "Sign up",
            url: "/forms/sign-up",
          },
        ],
      },
      {
        sectionTitle: "System Pages",
        links: [
          { title: "Links", url: "/system/links" },
          { title: "Buttons", url: "/system/buttons" },
          { title: "Colors", url: "/system/colors" },
          { title: "Typography", url: "/system/typography" },
          {
            title: "License",
            url: "https://lexingtonthemes.com/legal/license",
          },
          {
            title: "Docs",
            url: "https://lexingtonthemes.com/documentation",
          },
        ],
      },
    ],
  },
  {
    categoryTitle: "Content Collection",
    links: [
      {
        sectionTitle: "Blog Pages",
        links: [
          {
            title: "Blog Home",
            url: "/blog/home",
          },
          {
            title: "Blog Post",
            url: "/blog/posts/1",
          },
          { title: "Tag index", url: "/blog/tags" },
          {
            title: "Tag Category",
            url: "/blog/tags/health",
          },
          { title: "RSS", url: "/rss.xml" },
        ],
      },
      {
        sectionTitle: "Help Center",
        links: [
          {
            title: "Home",
            url: "/helpcenter/home",
          },
          {
            title: "Details",
            url: "/helpcenter/1",
          },
        ],
      },
      {
        sectionTitle: "Utility Pages",
        links: [
          {
            title: "Terms Of Use",
            url: "/infopages/terms",
          },
          {
            title: "Privacy Policy",
            url: "/infopages/privacy",
          },
        ],
      },
      {
        sectionTitle: "Integrations",
        links: [
          {
            title: "Home",
            url: "/integrations/home",
            ariaLabel: "link to integrations home",
          },
          {
            title: "Details",
            url: "/integrations/1",
            ariaLabel: "link to integrations details",
          },
        ],
      },
      {
        sectionTitle: "Changelog",
        links: [
          {
            title: "Home",
            url: "/changelog/home",
            ariaLabel: "link to changelog home",
          },
          {
            title: "Details",
            url: "/changelog/1",
            ariaLabel: "link to changelog details",
          },
        ],
      },
      {
        sectionTitle: "Team",
        links: [
          {
            title: "Home",
            url: "/team/home",
            ariaLabel: "link to team home",
          },
          {
            title: "Details",
            url: "/team/jordan-wells",
            ariaLabel: "link to team details",
          },
        ],
      },
      {
        sectionTitle: "Customers",
        links: [
          {
            title: "Home",
            url: "/customers/home",
            ariaLabel: "link to customers home",
          },
          {
            title: "Details",
            url: "/customers/1",
            ariaLabel: "link to customers details",
          },
        ],
      },
    ],
  },
];
---

<BaseLayout>
  <section class="relative overflow-hidden">
    <Burst />
    <Dots />
    <SectionDivider />
    <Wrapper variant="standard" class="relative pt-30 lg:pt-60 pb-28">
      <div class="items-start grid grid-cols-1 lg:grid-cols-8 gap-y-8">
        <Kicker> Overview</Kicker>
        <Text
          tag="h1"
          variant="displayMD"
          class="font-display text-base-900 lg:-mt-1 text-balance lg:col-span-7"
        >
          See all pages
        </Text>
      </div>
    </Wrapper>
  </section>
  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        {
          pageData.map((category) => (
            <>
              <div>
                <Text
                  tag="h2"
                  variant="textBase"
                  class="font-medium text-base-900 "
                >
                  {category.categoryTitle}
                </Text>
                <div class="mt-4 gap-y-8  grid grid-cols-2 lg:grid-cols-3">
                  {category.links.map((section) => (
                    <div>
                      <Text tag="h3" variant="textSM" class="text-base-900">
                        {section.sectionTitle}
                      </Text>
                      <div class="flex flex-col mt-4 text-xs gap-2 text-base-500">
                        {section.links.map((link) => (
                          <a
                            class="hover:text-base-900"
                            title={link.ariaLabel}
                            href={link.url}
                          >
                            {link.title}
                          </a>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </>
          ))
        }
      </div>
    </Wrapper>
  </section>
</BaseLayout>
