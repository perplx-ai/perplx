---
// Assets
import Dots from "@/components/assets/Dots.astro";
import Burst from "@/components/assets/Burst.astro";
import Kicker from "@/components/assets/Kicker.astro";
import SectionDivider from "@/components/assets/SectionDivider.astro";
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import CustomerEntry1 from "@/components/customers/CustomerEntry1.astro";
// Content
import { getCollection } from "astro:content";
const allCustomers = await getCollection("customers");
---

<BaseLayout>
  <section class="relative overflow-hidden">
    <Burst />
    <Dots />
    <SectionDivider />
    <Wrapper variant="standard" class="relative pt-30 lg:pt-60 pb-28">
      <div class="items-start grid grid-cols-1 lg:grid-cols-8 gap-y-8">
        <Kicker>Team</Kicker>
        <div class="lg:col-span-7 text-balance">
          <Text
            tag="h1"
            variant="displayMD"
            class="font-display text-base-900 lg:-mt-1 text-balance"
          >
            Real people. Real products. (Really.)
          </Text>
          <Text tag="p" variant="textBase" class="text-base-700 mt-1">
            These folks didn’t just sign up—they stuck around. Here’s who’s
            building cool stuff on our stack instead of yelling at it.
          </Text>
        </div>
      </div>
    </Wrapper>
  </section>

  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="flex flex-col gap-1">
        {allCustomers.map((post) => <CustomerEntry1 post={post} />)}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
