---
const { variant, size, class: className, ...rest } = Astro.props;
const xs = ["size-3"];
const sm = ["size-4"];
const base = ["size-5"];
const md = ["size-6"];
const lg = ["size-7"];
const xl = ["size-8"];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={[
    "icon",
    "icon-tabler",
    "icons-tabler-outline",
    "icon-tabler-arrow-search",
    size === "xs" && xs,
    size === "sm" && sm,
    size === "base" && base,
    size === "md" && md,
    size === "lg" && lg,
    size === "xl" && xl,
    className,
  ]}
  {...rest}
>
  <path
    d="M11 12.8182H8.14625C7.64422 12.8182 7.33593 12.2685 7.59771 11.8401L11.8086 4.94955C12.1472 4.39556 13 4.63552 13 5.28477V11.1818H15.8538C16.3558 11.1818 16.6641 11.7315 16.4023 12.1599L12.1914 19.0504C11.8528 19.6044 11 19.3645 11 18.7152V12.8182Z"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
  <path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
    d="M3 4m0 3a3 3 0 0 1 3 -3h12a3 3 0 0 1 3 3v2a3 3 0 0 1 -3 3h-12a3 3 0 0 1 -3 -3z"
  ></path><path
    d="M3 12m0 3a3 3 0 0 1 3 -3h12a3 3 0 0 1 3 3v2a3 3 0 0 1 -3 3h-12a3 3 0 0 1 -3 -3z"
  ></path><path d="M7 8l0 .01"></path><path d="M7 16l0 .01"></path></svg
>
