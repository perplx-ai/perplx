---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import playfulLollipopSpiralPath from "./playfulLollipopSpiral.txt?raw";

const snippets = [
  {
    title: "Python",
    code: `def climbStairs(self, n: int) -> int:
    a, b = 1, 1
    for _ in range(n - 1):
        a, b = b, a + b
    return b`,
  },
  {
    title: "Python",
    code: `def search(self, nums: List[int], t: int) -> bool:
    lo, hi = 0, len(nums) - 1
    while lo <= hi:
        mid = (lo + hi) // 2
        if nums[mid] == t:
            return True
        elif nums[mid] < t:
            lo = mid + 1
        else:
            hi = mid - 1
    return False`,
  },
  {
    title: "Python",
    code: `def numIslands(self, grid):
    def dfs(i, j):
        if not (0 <= i < m and 0 <= j < n) or grid[i][j] != "1":
            return
        grid[i][j] = "0"
        for di, dj in (0, 1), (1, 0), (0, -1), (-1, 0):
            dfs(i + di, j + dj)
    m, n = len(grid), len(grid[0])
    count = 0
    for i in range(m):
        for j in range(n):
            if grid[i][j] == "1":
                dfs(i, j)
                count += 1
    return count`,
  },
  {
    title: "Web",
    code: `<todo-application>
  #shadow-root
  <nav class="toolbar">…</nav>
  <todo-list>
    <todo-task done>Review API</todo-task>
    <todo-task>Ship v1</todo-task>
  </todo-list>
</todo-application>`,
  },
] as const;

const personas = [
  {
    name: "Scholar",
    blurb: "Careful study & craft",
    ariaLabel:
      "Scholar terminal persona: prompt shown as two eyes, monocle on the left",
  },
  {
    name: "Professional",
    blurb: "Senior-grade focus",
    ariaLabel: "Terminal persona with detective hat — professional",
  },
  {
    name: "Playful",
    blurb: "Learn by doing",
    ariaLabel:
      "Terminal persona with propeller hat and line-art swirl lollipop on a stick",
  },
] as const;
---

<section
  class="relative overflow-hidden bg-linear-to-b from-base-50 to-base-100"
  style="--perplexity-blue: #3b7a87;"
>
  <Wrapper variant="standard" class="relative py-16 md:py-24 lg:py-28">
    <h1
      class="mx-auto max-w-6xl text-center leading-[1.15] tracking-wide text-[#3b7a87]"
      style="font-family: var(--font-pixel); font-size: clamp(22px, 5vw, 60px);"
    >
      WELCOME TO PERPLEX
    </h1>

    <!-- Octopus + legs: one SVG; 8-bit stepped legs (shorter than classic terminal-mascot) -->
    <div class="mx-auto mt-10 max-w-6xl md:mt-12">
      <svg
        class="mx-auto block h-auto w-full max-w-6xl"
        viewBox="0 0 800 188"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        preserveAspectRatio="xMidYMin meet"
      >
        <title>Terminal octopus</title>
        <!-- Head + legs: crisp edges for 8-bit look; text uses default rendering -->
        <g shape-rendering="crispEdges">
        <rect
          x="220"
          y="16"
          width="360"
          height="88"
          fill="var(--perplexity-blue)"></rect>
        </g>
        <!-- Prompt as two eyes: tight pair so they read as eyes, not prompt syntax -->
        <text
          fill="white"
          class="font-mono font-bold"
          style="font-size: 36px;"
          aria-hidden="true"
        >
          <tspan x="389" y="76" text-anchor="middle">&gt;</tspan>
          <tspan x="411" y="72" text-anchor="middle">_</tspan>
        </text>
        <!-- Four short 8-bit legs: outer pair = square hook feet; inner = simple elbow (like reference, compressed) -->
        <g
          shape-rendering="crispEdges"
          fill="none"
          stroke="var(--perplexity-blue)"
          stroke-width="8"
          stroke-linecap="square"
          stroke-linejoin="miter"
        >
          <!-- outer left: down → left → up → right → down toward column -->
          <path d="M 252 104 V 132 H 232 V 124 H 248 V 148 H 104 V 172"></path>
          <!-- inner left -->
          <path d="M 364 104 V 136 H 304 V 172"></path>
          <!-- inner right -->
          <path d="M 436 104 V 172"></path>
          <!-- outer right: mirror hook -->
          <path d="M 548 104 V 132 H 568 V 124 H 552 V 148 H 696 V 172"></path>
        </g>
      </svg>

      <div
        class="grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-5 lg:mt-1 lg:grid-cols-4 lg:gap-4"
      >
        {
          snippets.map((snip) => (
            <div class="flex min-h-0 flex-col">
              <div
                class="overflow-hidden rounded-b-lg rounded-t-none border border-x border-b border-base-200 border-t-4 border-t-[#3b7a87] bg-base-950 shadow-[var(--shadow-subtle)]"
              >
                <div class="flex items-center justify-between border-b border-base-800 px-3 py-2">
                  <span class="font-mono text-xs text-base-400">{snip.title}</span>
                  <span class="h-2 w-2 rounded-full bg-[#3b7a87]/80" aria-hidden="true" />
                </div>
                <pre
                  class="max-h-52 overflow-x-auto overflow-y-auto p-3 text-left font-mono text-[10px] leading-relaxed text-base-100 sm:text-xs lg:max-h-60"
                  tabindex="0"
                ><code class="whitespace-pre text-[#a5d6ff]">{snip.code}</code></pre>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Copy under octopus + code -->
    <div class="mx-auto mt-14 max-w-3xl text-center md:mt-20">
      <Text
        tag="p"
        variant="displayMD"
        class="font-display text-balance text-base-900"
      >
        Knowledge is enough -- The agent for everyone
      </Text>
      <Text
        tag="p"
        variant="textXL"
        class="mt-4 text-balance text-base-600"
      >
        Senior Developers at the tip of your fingers
      </Text>
    </div>

    <!-- Personas: no boxes, larger art only -->
    <div
      class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-12 sm:grid-cols-3 sm:gap-10 md:mt-20 lg:gap-14"
    >
      {
        personas.map((p, i) => (
          <figure
            class="flex flex-col items-center text-center"
            aria-label={p.ariaLabel}
          >
            <div class="flex min-h-[14rem] w-full items-center justify-center sm:min-h-[16rem] md:min-h-[18rem]">
              {i === 0 && (
                <svg
                  viewBox="0 0 160 132"
                  class="h-52 w-full max-w-[14rem] md:h-64 md:max-w-[16rem]"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <g shape-rendering="crispEdges">
                  <rect
                    x="20"
                    y="52"
                    width="120"
                    height="44"
                    fill="#3b7a87"
                  />
                  </g>
                  <text fill="white" class="font-mono" style="font-size: 18px;">
                    <tspan x="74" y="79" text-anchor="middle">&gt;</tspan>
                    <tspan x="86" y="73" text-anchor="middle">_</tspan>
                  </text>
                  <!-- Monocle on the &gt; eye only -->
                  <circle
                    cx="74"
                    cy="69"
                    r="8"
                    stroke="#3b7a87"
                    stroke-width="2.5"
                    shape-rendering="geometricPrecision"
                    fill="rgba(255,255,255,0.12)"
                  />
                  <path
                    d="M82 69 L96 62 L108 53"
                    stroke="#3b7a87"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    shape-rendering="geometricPrecision"
                  />
                  <circle
                    cx="110"
                    cy="52"
                    r="2"
                    fill="#3b7a87"
                    shape-rendering="geometricPrecision"
                  />
                  <g
                    shape-rendering="crispEdges"
                    fill="none"
                    stroke="#3b7a87"
                    stroke-width="4"
                    stroke-linecap="square"
                    stroke-linejoin="miter"
                  >
                    <path d="M 36 96 V 106 H 28 V 100 H 40 V 114 H 26 V 126"></path>
                    <path d="M 56 96 V 110 H 50 V 126"></path>
                    <path d="M 104 96 V 126"></path>
                    <path d="M 124 96 V 106 H 132 V 100 H 120 V 114 H 134 V 126"></path>
                  </g>
                </svg>
              )}
              {i === 1 && (
                <svg
                  viewBox="0 0 160 132"
                  class="h-52 w-full max-w-[14rem] md:h-64 md:max-w-[16rem]"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <g shape-rendering="crispEdges">
                    <path
                      d="M36 48 L124 48 L114 28 L46 28 Z"
                      fill="#3b7a87"
                    />
                    <ellipse cx="80" cy="50" rx="52" ry="6" fill="#2d5f6a" />
                    <rect
                      x="28"
                      y="56"
                      width="104"
                      height="44"
                      fill="#3b7a87"
                    />
                  </g>
                  <text fill="white" class="font-mono" style="font-size: 18px;">
                    <tspan x="74" y="86" text-anchor="middle">&gt;</tspan>
                    <tspan x="86" y="82" text-anchor="middle">_</tspan>
                  </text>
                  <g
                    shape-rendering="crispEdges"
                    fill="none"
                    stroke="#3b7a87"
                    stroke-width="4"
                    stroke-linecap="square"
                    stroke-linejoin="miter"
                  >
                    <path d="M 40 100 V 108 H 32 V 102 H 44 V 116 H 30 V 126"></path>
                    <path d="M 58 100 V 112 H 52 V 126"></path>
                    <path d="M 102 100 V 126"></path>
                    <path d="M 120 100 V 108 H 128 V 102 H 116 V 116 H 130 V 126"></path>
                  </g>
                </svg>
              )}
              {i === 2 && (
                <svg
                  viewBox="0 0 180 132"
                  class="h-52 w-full max-w-[15rem] md:h-64 md:max-w-[17rem]"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path
                    d="M62 44 C62 26 98 26 98 44 L98 50 L62 50 Z"
                    fill="#3b7a87"
                    shape-rendering="geometricPrecision"
                  />
                  <g
                    stroke="#3b7a87"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    shape-rendering="geometricPrecision"
                  >
                    <line x1="80" y1="28" x2="80" y2="16" />
                    <line x1="72" y1="22" x2="88" y2="22" />
                    <line x1="74" y1="16" x2="86" y2="28" />
                    <line x1="74" y1="28" x2="86" y2="16" />
                  </g>
                  <g shape-rendering="crispEdges">
                  <rect
                    x="40"
                    y="58"
                    width="100"
                    height="44"
                    fill="#3b7a87"
                  />
                  </g>
                  <text fill="white" class="font-mono" style="font-size: 18px;">
                    <tspan x="84" y="88" text-anchor="middle">&gt;</tspan>
                    <tspan x="96" y="84" text-anchor="middle">_</tspan>
                  </text>
                  <!-- Lollipop: thin circle + continuous center spiral + straight stick (sketch-style) -->
                  <g shape-rendering="geometricPrecision">
                    <line
                      x1="148"
                      y1="88"
                      x2="148"
                      y2="122"
                      stroke="#3b7a87"
                      stroke-width="1.75"
                      stroke-linecap="round"
                    />
                    <circle
                      cx="148"
                      cy="71"
                      r="17"
                      fill="#ffffff"
                      stroke="#3b7a87"
                      stroke-width="1.75"
                    />
                    <path
                      d={playfulLollipopSpiralPath.trim()}
                      fill="none"
                      stroke="#3b7a87"
                      stroke-width="1.45"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </g>
                  <g
                    shape-rendering="crispEdges"
                    fill="none"
                    stroke="#3b7a87"
                    stroke-width="4"
                    stroke-linecap="square"
                    stroke-linejoin="miter"
                  >
                    <path d="M 54 102 V 110 H 46 V 104 H 58 V 118 H 44 V 128"></path>
                    <path d="M 72 102 V 114 H 66 V 128"></path>
                    <path d="M 108 102 V 128"></path>
                    <path d="M 126 102 V 110 H 134 V 104 H 122 V 118 H 136 V 128"></path>
                  </g>
                </svg>
              )}
            </div>
            <figcaption class="mt-6">
              <p class="font-display text-lg font-semibold text-base-900 md:text-xl">
                {p.name}
              </p>
              <p class="mt-2 text-sm text-base-600 md:text-base">{p.blurb}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </Wrapper>
</section>
