---
// Assets
import Dots from "@/components/assets/Dots.astro";
import Burst from "@/components/assets/Burst.astro";
import Kicker from "@/components/assets/Kicker.astro";
import SectionDivider from "@/components/assets/SectionDivider.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const highlights = [
  {
    title: "Does the research for you",
    body: "Pulls live docs and package sources instead of guessing from a training snapshot—so recommendations track today’s APIs and release notes without you opening a dozen tabs.",
  },
  {
    title: "Summaries with every move",
    body: "Suggested commands and file edits ship with a short explanation: what will happen, why it’s proposed, and what to verify—so nothing feels like a black box.",
  },
  {
    title: "Smoother from prompt to merge",
    body: "Stays aligned with your stack and workflow so the agent feels like an extension of how you already code—not a parallel universe of one-off steps.",
  },
] as const;
---

<section class="relative overflow-hidden">
  <Burst side="right" />
  <Dots />
  <SectionDivider />
  <SectionDivider flipped={true} />

  <Wrapper variant="standard" class="py-24">
    <div class="items-start grid grid-cols-1 lg:grid-cols-8 gap-y-8">
      <Kicker>Product</Kicker>
      <div class="relative lg:col-span-7">
        <Text
          tag="h2"
          variant="displaySM"
          class="font-display text-base-900 text-balance lg:-mt-1"
        >
          Does the research for you—then stays transparent about every
          suggestion and seamless in your real workflow.
        </Text>
        <div class="mt-16 flex flex-col gap-6">
          {
            highlights.map((h) => (
              <div class="border-b border-base-100 pb-6 last:border-b-0 last:pb-0">
                <Text tag="h3" variant="textBase" class="text-base-900">
                  {h.title}
                </Text>
                <Text tag="p" variant="textBase" class="mt-2 text-base-500">
                  {h.body}
                </Text>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>
